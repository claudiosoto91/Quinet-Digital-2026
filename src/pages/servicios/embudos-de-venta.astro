---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Embudos de Venta">
	
	<section class="bg-quinet-dark text-white pt-32 pb-20 relative overflow-hidden flex items-center min-h-[70vh]">
		<div class="absolute inset-0 overflow-hidden pointer-events-none -z-10">
			<div class="absolute top-[-10%] left-[-10%] w-[600px] h-[600px] rounded-full bg-quinet-teal/20 blur-[150px]"></div>
		</div>
		
		<div class="max-w-screen-xl mx-auto px-4 relative z-10 w-full">
			<div class="max-w-3xl">
				<span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-quinet-gold text-xs font-bold uppercase mb-6 backdrop-blur-md">
					Sistemas Automatizados 🌪️
				</span>
				<h1 class="font-display text-5xl md:text-7xl font-extrabold mb-6 leading-tight tracking-tighter">
					Dejá de perseguir clientes. <br>
					<span class="text-gradient-teal">Hacé que ellos te busquen.</span>
				</h1>
				<p class="text-xl text-white/80 font-sans mb-10 max-w-2xl leading-relaxed">
					Un sitio web normal informa. Un **Funnel de Quinet** guía al usuario paso a paso hacia la compra.
				</p>
				<a href="#proceso" class="inline-block px-8 py-4 bg-quinet-gold text-quinet-dark font-bold rounded-full shadow-[0_0_20px_rgba(233,196,106,0.4)]">
					¿Cómo funciona el embudo? 👇
				</a>
			</div>
		</div>
	</section>

	<section id="proceso" class="bg-quinet-light py-24">
		<div class="max-w-screen-xl mx-auto px-4">
			<div class="text-center mb-16">
				<h2 class="font-display uppercase text-4xl md:text-5xl font-extrabold text-quinet-dark mb-4">Tu camino a la <span class="text-quinet-teal">automatización</span></h2>
				<p class="text-quinet-dark/60 text-lg">3 etapas clave para transformar tu negocio.</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				{['Captación', 'Adoctrinamiento', 'Conversión'].map((step, i) => (
					<div class="bg-white p-10 rounded-[2.5rem] shadow-xl border border-black/5 relative group overflow-hidden">
						<div class="text-6xl font-black text-quinet-teal/10 absolute -top-2 -right-2 group-hover:text-quinet-teal/20 transition-colors">{i + 1}</div>
						<div class="w-16 h-16 bg-quinet-dark rounded-2xl flex items-center justify-center text-quinet-gold text-2xl font-bold mb-6">
							{i === 0 ? '🎯' : i === 1 ? '🧠' : '💰'}
						</div>
						<h3 class="font-display text-2xl font-bold mb-4">{step}</h3>
						<p class="text-quinet-dark/70 text-sm leading-relaxed">
							{i === 0 && "Atraemos tráfico cualificado a una Landing Page optimizada."}
							{i === 1 && "Educamos al cliente automáticamente mediante contenido de valor."}
							{i === 2 && "El sistema entrega al cliente listo para comprar o agendar."}
						</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="bg-white py-24 px-4">
		<div class="max-w-4xl mx-auto">
			<div class="bg-quinet-dark rounded-[3rem] overflow-hidden shadow-2xl border border-white/10">
				<div class="p-8 text-center bg-white/5 border-b border-white/10">
					<h2 class="font-display text-2xl font-bold text-white uppercase tracking-widest">Diferencia Estratégica</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2">
					<div class="p-10 border-b md:border-b-0 md:border-r border-white/10">
						<p class="text-red-400 font-bold uppercase text-xs mb-6 flex items-center gap-2">
							<span>✕</span> Web Tradicional
						</p>
						<ul class="space-y-4 text-white/90">
							<li class="flex items-center gap-3 text-sm">🔴 Distracciones masivas</li>
							<li class="flex items-center gap-3 text-sm">🔴 El usuario se pierde</li>
							<li class="flex items-center gap-3 text-sm">🔴 Baja conversión</li>
						</ul>
					</div>
					<div class="p-10 bg-white/5">
						<p class="text-quinet-teal font-bold uppercase text-xs mb-6 flex items-center gap-2">
							<span>✓</span> Quinet Funnel
						</p>
						<ul class="space-y-4 text-white font-bold">
							<li class="flex items-center gap-3 text-sm"><span class="text-quinet-teal">✔</span> Objetivo de venta único</li>
							<li class="flex items-center gap-3 text-sm"><span class="text-quinet-teal">✔</span> Camino guiado (UX)</li>
							<li class="flex items-center gap-3 text-sm"><span class="text-quinet-teal">✔</span> Alta rentabilidad</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="bg-white pb-24 px-4">
		<div class="max-w-screen-xl mx-auto">
			<div class="bg-quinet-teal rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden shadow-2xl">
				<div class="absolute inset-0 bg-gradient-to-br from-black/20 to-transparent pointer-events-none"></div>
				<div class="relative z-10">
					<h2 class="font-display text-4xl md:text-6xl font-extrabold text-quinet-dark mb-8">
						Poné tu negocio en <br> <span class="text-white">piloto automático.</span>
					</h2>
					<div class="flex justify-center">
						<a href="https://wa.me/+543812529020" class="group flex items-center gap-4 px-10 py-5 bg-quinet-dark text-white font-black rounded-full hover:scale-105 transition-all shadow-2xl">
							<span class="text-white">QUIERO MI EMBUDO</span>
							<span class="text-2xl group-hover:rotate-12 transition-transform">🚀</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

</Layout>